# SimpleMem MCP Server - Docker environment template
# Updated for local Ollama usage

# Required for production
JWT_SECRET_KEY=your-secure-random-secret-key
ENCRYPTION_KEY=your-32-byte-encryption-key!!

# LLM provider: openrouter | ollama
LLM_PROVIDER=ollama

# When using Ollama on host: use host.docker.internal to reach host from container
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# OpenRouter (not used when LLM_PROVIDER=ollama)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models - Updated for your local Gemma 4
LLM_MODEL=gemma4-optimized:latest
EMBEDDING_MODEL=gemma4-optimized:latest
EMBEDDING_DIMENSION=2560

# Data directory inside container
# DATA_DIR=/app/MCP/data